### ------------------------------------------------------------------------
### 场景一：创建一个草稿报销单并初始化第一段行程（保存主单接口）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_Save
Content-Type: application/json

{
  "id": "",
  "version": 0,
  "reimbursementTitle": "6月份大湾区市场拓展差旅报销-张三",
  "businessTripReason": "赴广州、深圳、东莞三地进行线下客户拜访与合同签约",
  "reimburserId": "emp_1002",
  "reimburserNo": "10002",
  "reimburserName": "张三",
  "reimDepartmentId": "dept_002",
  "reimDepartmentNo": "D002",
  "reimDepartmentName": "市场部",
  "reimCompanyId": "comp_001",
  "reimCompanyNo": "C001",
  "reimCompanyName": "费控云科技有限公司",
  "businessTypeId": "bt_001",
  "businessTypeNo": "BT-TRIP",
  "businessTypeName": "国内差旅报销",
  "subsidyTotal": 0,
  "mealAllowance": 0,
  "transportationAllowance": 0,
  "phoneAllowance": 0,
  "remarks": "单据较多，请财务尽快审核",
  "tripList": [],
  "splitList": [
    {
      "id": "",
      "reimId": "",
      "sortNo": 1,
      "companyId": "comp_001",
      "companyName": "费控云科技有限公司",
      "projectId": "proj_200",
      "projectName": "大客户拓展专项资金",
      "splitRatio": 0.5000,
      "splitAmount": 0
    },
    {
      "id": "",
      "reimId": "",
      "sortNo": 2,
      "companyId": "comp_003",
      "companyName": "深圳分公司",
      "projectId": "proj_201",
      "projectName": "华南区市场推广",
      "splitRatio": 0.5000,
      "splitAmount": 0
    }
  ]
}

> {%
    client.global.set("reimId", response.body.data.id);
%}


### ------------------------------------------------------------------------
### 场景二：补录第一段行程（广州 -> 深圳）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_SaveTrip
Content-Type: application/json

{
  "id": "",
  "reimId": "{{reimId}}",
  "travelerId": "emp_1002",
  "travelerNo": "10002",
  "travelerName": "张三",
  "departureCityId": "city_gz",
  "departureCityName": "广州市",
  "arriveCityId": "city_sz",
  "arriveCityName": "深圳市",
  "arriveCityLevel": "1",
  "departureDate": "2026-05-10",
  "arriveDate": "2026-05-12",
  "tripDesc": "第一段：高铁从广州前往深圳拜访客户A"
}
> {%
    client.global.set("subsidyId_1", response.body.data.subsidyId);
%}

### ------------------------------------------------------------------------
### 场景三：补录第二段行程（深圳 -> 东莞）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_SaveTrip
Content-Type: application/json

{
  "id": "",
  "reimId": "{{reimId}}",
  "travelerId": "emp_1002",
  "travelerNo": "10002",
  "travelerName": "张三",
  "departureCityId": "city_sz",
  "departureCityName": "深圳市",
  "arriveCityId": "city_dg",
  "arriveCityName": "东莞市",
  "arriveCityLevel": "2",
  "departureDate": "2026-05-13",
  "arriveDate": "2026-05-14",
  "tripDesc": "第二段：拼车从深圳前往东莞拜访客户B"
}
> {%
    client.global.set("tripId_2", response.body.data.tripId);
%}
### ------------------------------------------------------------------------
### 场景四：验证行程冲突拦截（时间重叠测试）
### 预期：应该报错 REIM_003，因为 5月11日 已经在深圳了
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_SaveTrip
Content-Type: application/json

{
  "id": "",
  "reimId": "{{reimId}}",
  "travelerId": "emp_1002",
  "travelerNo": "10002",
  "travelerName": "张三",
  "departureCityId": "city_sz",
  "departureCityName": "深圳市",
  "arriveCityId": "city_zh",
  "arriveCityName": "珠海市",
  "arriveCityLevel": "2",
  "departureDate": "2026-05-11",
  "arriveDate": "2026-05-12",
  "tripDesc": "故意重叠的错误行程（时间冲突测试）"
}


### ------------------------------------------------------------------------
### 场景五：查询第一段行程（去深圳）生成的补助日历明细
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_GetCalendar
Content-Type: application/json

{
  "reimId": "{{reimId}}",
  "subsidyId": "{{subsidyId_1}}"
}

> {%
    // 抓取第1天的日历ID，用于下一步的金额修改
    client.global.set("calendarId_Day1", response.body.data[0].id);
%}


### ------------------------------------------------------------------------
### 场景六：修改补助日历并保存（级联核心测试）
### 业务描述：到深圳的第一天自己打车了，没用公司车，所以取消了当天的“交通补助”勾选
### 预期结果：保存后，主单的总补助金额扣减 40元 交通补助
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_SaveSubsidy
Content-Type: application/json

{
  "subsidyId": "{{subsidyId_1}}",
  "calendarList": [
    {
      "id": "{{calendarId_Day1}}",
      "mealChecked": 1,
      "mealAmount": 100.00,
      "transportChecked": 0,
      "transportAmount": 0.00,
      "phoneChecked": 1,
      "phoneAmount": 40.00
    }
  ]
}


### ------------------------------------------------------------------------
### 场景七：删除不需要的行程（级联删除测试）
### 业务描述：发现第二段东莞行程被取消了，执行删除
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_DeleteTrip
Content-Type: application/json

{
  "id": "{{tripId_2}}",
  "reimId": "{{reimId}}"
}


### ------------------------------------------------------------------------
### 场景八：多条件分页查询报销单列表（业务查询测试）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_QueryPageList
Content-Type: application/json

{
  "current": 1,
  "size": 10,
  "reimTitle": "市场拓展",
  "reimburserId": "emp_1002",
  "companyId": "comp_001"
}


### ------------------------------------------------------------------------
### 场景九：查看报销单最终详情（重点看补助金额和分摊比例对不对）
### ------------------------------------------------------------------------
GET http://localhost:8080/api/fccapi/REIM_GetDetail?id={{reimId}}
Accept: application/json

> {%
    // 获取当前最新的乐观锁版本号，为提交做准备
    client.global.set("currentVersion", response.body.data.version);
%}


### ------------------------------------------------------------------------
### 场景十：提交报销单并启动审批流（主流程闭环）
### 预期结果：状态变为已完成，AOP拦截写日志
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_Submit
Content-Type: application/json

{
  "id": "{{reimId}}",
  "version": {{currentVersion}}
}


### ------------------------------------------------------------------------
### 场景十一：BPM 审批状态回调更新（模拟第三方）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_UpdateStatus
Content-Type: application/json

{
  "id": "{{reimId}}",
  "status": 2,
  "remark": "BPM节点审核：市场部总监已批"
}