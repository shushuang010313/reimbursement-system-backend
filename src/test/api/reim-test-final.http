### ------------------------------------------------------------------------
### 准备工作：
### 请确保你的 Spring Boot 服务已启动，且端口为 8080。
### 以下请求可以直接按顺序点击每块左侧的绿色箭头执行。
### 所有动态关联的 ID 都会被 IDEA 自动捕获并传递，实现真正的全链路自动化联调！
### ------------------------------------------------------------------------

### ------------------------------------------------------------------------
### 场景一：创建一个草稿报销单并初始化分摊数据（保存主单接口）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_Save
Content-Type: application/json

{
  "id": "",
  "version": 0,
  "reimbursementTitle": "5月中旬华东区技术交流差旅-李四",
  "businessTripReason": "赴上海、杭州、苏州进行研发技术交流与架构研讨",
  "reimburserId": "emp_1003",
  "reimburserNo": "10003",
  "reimburserName": "李四",
  "reimDepartmentId": "dept_003",
  "reimDepartmentNo": "D003",
  "reimDepartmentName": "研发中心",
  "reimCompanyId": "comp_001",
  "reimCompanyNo": "C001",
  "reimCompanyName": "费控云科技有限公司",
  "businessTypeId": "bt_001",
  "businessTypeNo": "BT-TRIP",
  "businessTypeName": "国内差旅报销",
  "subsidyTotal": 0,
  "mealAllowance": 0,
  "transportationAllowance": 0,
  "phoneAllowance": 0,
  "remarks": "请领导审批",
  "tripList": [],
  "splitList": [
    {
      "id": "",
      "reimId": "",
      "sortNo": 1,
      "companyId": "comp_001",
      "companyName": "费控云科技有限公司",
      "projectId": "proj_300",
      "projectName": "新一代架构研发资金",
      "splitRatio": 0.6000, 
      "splitAmount": 0
    },
    {
      "id": "",
      "reimId": "",
      "sortNo": 2,
      "companyId": "comp_002",
      "companyName": "杭州研发中心",
      "projectId": "proj_301",
      "projectName": "杭州本地技术共建",
      "splitRatio": 0.4000, 
      "splitAmount": 0
    }
  ]
}

> {%
    // 捕获新创建的报销单 ID
    client.global.set("reimId", response.body.data.id);
%}


### ------------------------------------------------------------------------
### 场景二：补录第一段行程（上海 -> 杭州）
### 注意：因为修改过代码，现在返回结果里包含了 tripId 和 subsidyId
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_SaveTrip
Content-Type: application/json

{
  "id": "",
  "reimId": "{{reimId}}",
  "travelerId": "emp_1003",
  "travelerNo": "10003",
  "travelerName": "李四",
  "departureCityId": "city_sh",
  "departureCityName": "上海市",
  "arriveCityId": "city_hz",
  "arriveCityName": "杭州市",
  "arriveCityLevel": "1", 
  "departureDate": "2026-05-15",
  "arriveDate": "2026-05-17",
  "tripDesc": "第一段：从上海乘高铁前往杭州总部开会"
}

> {%
    // 自动捕获这一段行程生成的补助记录 ID，传给下一个场景使用
    client.global.set("subsidyId_1", response.body.data.subsidyId);
%}


### ------------------------------------------------------------------------
### 场景三：补录第二段行程（杭州 -> 苏州）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_SaveTrip
Content-Type: application/json

{
  "id": "",
  "reimId": "{{reimId}}",
  "travelerId": "emp_1003",
  "travelerNo": "10003",
  "travelerName": "李四",
  "departureCityId": "city_hz",
  "departureCityName": "杭州市",
  "arriveCityId": "city_sz_js",
  "arriveCityName": "苏州市",
  "arriveCityLevel": "2",
  "departureDate": "2026-05-18",
  "arriveDate": "2026-05-20",
  "tripDesc": "第二段：杭州会议结束前往苏州分公司培训"
}

> {%
    client.global.set("tripId_2", response.body.data.tripId);
%}


### ------------------------------------------------------------------------
### 场景四：验证行程冲突拦截（故意制造时间重叠）
### 预期：报错参数错误/行程冲突，因为 5月16日 已经在杭州了
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_SaveTrip
Content-Type: application/json

{
  "id": "",
  "reimId": "{{reimId}}",
  "travelerId": "emp_1003",
  "travelerNo": "10003",
  "travelerName": "李四",
  "departureCityId": "city_hz",
  "departureCityName": "杭州市",
  "arriveCityId": "city_nj",
  "arriveCityName": "南京市",
  "arriveCityLevel": "2",
  "departureDate": "2026-05-16",
  "arriveDate": "2026-05-17",
  "tripDesc": "故意重叠的错误行程（时间冲突测试）"
}


### ------------------------------------------------------------------------
### 场景五：查询第一段行程（去杭州）生成的补助日历明细
### 预期：应该返回 15日、16日、17日 共三天的补助日历记录
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_GetCalendar
Content-Type: application/json

{
  "reimId": "{{reimId}}",
  "subsidyId": "{{subsidyId_1}}"
}

> {%
    // 抓取第1天的日历ID，用于下一步的金额修改
    client.global.set("calendarId_Day1", response.body.data[0].id);
%}


### ------------------------------------------------------------------------
### 场景六：修改补助日历并保存（级联金额重算核心测试）
### 业务描述：到杭州的第一天自己打车了，没用公司车，所以取消了当天的“交通补助”勾选
### 预期结果：保存后，会自动触发重新计算，该段行程的总补助金额会扣减交通补助
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_SaveSubsidy
Content-Type: application/json

{
  "subsidyId": "{{subsidyId_1}}",
  "calendarList": [
    {
      "id": "{{calendarId_Day1}}",
      "mealChecked": 1, 
      "mealAmount": 100.00,
      "transportChecked": 0,
      "transportAmount": 0.00,
      "phoneChecked": 1,
      "phoneAmount": 40.00
    }
  ]
}


### ------------------------------------------------------------------------
### 场景七：删除不需要的行程（级联删除测试）
### 业务描述：发现第二段去苏州的行程被取消了，执行删除
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_DeleteTrip
Content-Type: application/x-www-form-urlencoded

tripId={{tripId_2}}


### ------------------------------------------------------------------------
### 场景八：多条件分页查询报销单列表（业务查询测试）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_QueryPageList
Content-Type: application/json

{
  "current": 1,
  "size": 10,
  "reimTitle": "技术交流",
  "reimburserId": "emp_1003",
  "companyId": "comp_001"
}


### ------------------------------------------------------------------------
### 场景九：查看报销单最终详情（重点看补助金额和分摊比例对不对）
### ------------------------------------------------------------------------
GET http://localhost:8080/api/fccapi/REIM_GetDetail?id={{reimId}}
Accept: application/json

> {%
    // 获取当前最新的乐观锁版本号，为提交做准备
    client.global.set("currentVersion", response.body.data.version);
%}


### ------------------------------------------------------------------------
### 场景十：提交报销单并启动审批流（主流程闭环）
### 预期结果：状态变为已完成，并触发乐观锁校验
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_Submit
Content-Type: application/json

{
  "id": "{{reimId}}",
  "version": {{currentVersion}}
}


### ------------------------------------------------------------------------
### 场景十一：BPM 审批状态回调更新（模拟第三方）
### ------------------------------------------------------------------------
POST http://localhost:8080/api/fccapi/REIM_UpdateStatus
Content-Type: application/json

{
  "id": "{{reimId}}",
  "status": 2,
  "remark": "BPM节点审核：研发中心总监已批"
}
