    }
  ]
}

> {%
    if (response.body.code == 200) {
        client.global.set("mqReimId", response.body.data.id);
        client.log(">>> MQ测试报销单ID: " + response.body.data.id);
    }
%}


###
# 4.2 【亮点三核心测试】提交报销单 — 触发MQ异步推送
# ⚠️ 观察控制台日志! 时间线:
#    T+0s:  日志 "【BPM消费者】接收到报销单提交消息..."
#    T+0s:  日志 "【BPM消费者】调用BPM系统接口发生网络超时异常！(演示用途)"
#    T+2s:  第1次重试 (initial-interval=2000)
#    T+6s:  第2次重试 (multiplier=2, 间隔=4s)
#    T+16s: 第3次重试 (max-interval=10000)
#    T+16s: 日志 "【严重告警】向BPM推送报销单(ID: xxx)失败，重试3次已耗尽！"
#
# ⚠️ 注意: version 必须与查询结果一致 (新保存的单 version=0)
POST {{fccApi}}/REIM_Submit
Content-Type: application/json
user-id: user-001

{
  "id": "{{mqReimId}}",
  "version": 0
}


###
# 4.3 【亮点三验证A】查询本地消息表 (在 IDEA Database 窗口执行)
#
# SELECT * FROM fk_reim_db.fk_mq_message WHERE business_id = '{{mqReimId}}' ORDER BY creation_time DESC;
#
# 预期:
#   - topic = 'reim.submit.topic'
#   - status: 1=发送成功, 2=发送失败(等待补偿)
#   - message_content 包含报销单ID


###
# 4.4 【亮点三验证B】在 RabbitMQ 管理界面查看死信队列
# 浏览器打开: http://192.168.40.128:15672  (账号: itcast / 密码: 123456)
# 导航: Queues → 找到 "reim.dlx.queue" → 查看 Ready messages
# 预期: reim.dlx.queue 中有消息堆积 (Total > 0)


###
# 4.5 【亮点三验证C】检查补偿任务日志
# 每5分钟执行一次，观察控制台:
#   "开始执行BPM审批流推送补偿任务..."
#   "补偿推送报销单 xxx 到 MQ"


###############################################################################
#  第四章: 🌟 亮点四 — 百万级数据防OOM异步导出 (EasyExcel + 自定义线程池)
#
#  代码位置:
#    - controller/ExportController.java     (导出控制器)
#    - service/AsyncExportService.java      (异步导出服务, @Async)
#    - config/ThreadPoolConfig.java         (导出专用线程池)
#    - vo/ExportTaskVO.java                 (任务状态VO)
#    - vo/ReimExportVO.java                 (导出VO, EasyExcel注解)
#    - entity/FkAsyncTask.java              (异步任务表实体)
#
#  验证目标:
#    1. 提交导出任务后立即返回 taskId (不阻塞)
#    2. 轮询进度接口能看到 progress 逐步增长
#    3. 数据库 fk_async_task 表记录了任务状态
#    4. 下载的 Excel 文件中身份证和银行卡是脱敏后的
#    5. 系统不会 OOM (分页查询, 每页1000条, 流式写入)
#
#  步骤: 提交任务 → 轮询进度 → 下载文件
###############################################################################

###
# 5.1 【亮点四 Step1】提交异步导出任务 — 立即返回 taskId (异步!)
POST {{exportApi}}/async
Content-Type: application/json

{
  "current": 1,
  "size": 10
}

> {%
    if (response.body.code == 200) {
        client.global.set("exportTaskId", response.body.data.taskId);
        client.log(">>> 导出任务已提交, taskId=" + response.body.data.taskId);
    }
%}


###
# 5.2 【亮点四 Step2】轮询任务进度 — 建议间隔2秒多次发送
# 预期响应:
#   处理中: {"code":200,"data":{"status":"PROCESSING","progress":45}}
#   已完成: {"code":200,"data":{"status":"SUCCESS","progress":100,
#            "downloadUrl":"/api/reim/export/download/xxx"}}
#   失败:   {"code":200,"data":{"status":"FAILED","errorMsg":"..."}}
GET {{exportApi}}/status/{{exportTaskId}}


###
# 5.3 【亮点四 Step3】下载生成的 Excel 文件 — 另存为 .xlsx 打开验证
# 验证内容:
#   - 列: 报销单号、报销标题、报销人、报销部门、出差事由、补助总金额
#        收款人身份证号(脱敏)、收款人银行账号(脱敏)、创建时间、单据状态
#   - 身份证显示如 "110105********1234"
#   - 银行卡显示如 "6222****1234"
GET {{exportApi}}/download/{{exportTaskId}}


###
# 5.4 【亮点四变体】通过主控制器接口提交导出 (同一逻辑, 不同入口)
POST {{fccApi}}/REIM_ExportAsync
Content-Type: application/json
user-id: user-001

{
  "current": 1,
  "size": 10
}

> {%
    if (response.body.code == 200) {
        client.global.set("exportTaskId2", response.body.data.taskId);
        client.log(">>> 导出任务(主接口)已提交, taskId=" + response.body.data.taskId);
    }
%}


###
# 5.5 【亮点四变体】查询导出任务状态 (主接口入口)
GET {{fccApi}}/REIM_ExportStatus?taskId={{exportTaskId2}}


###
# 5.6 【亮点四验证】数据库验证异步任务表
# 在 IDEA Database 窗口执行:
# SELECT id, task_name, task_type, status, progress, file_url
# FROM fk_reim_db.fk_async_task ORDER BY creation_time DESC LIMIT 5;
#
# 预期: status=2 (成功), progress=100, file_url 有文件路径


###
# 5.7 【亮点四】带查询条件的导出
POST {{exportApi}}/async
Content-Type: application/json

{
  "current": 1,
  "size": 10,
  "reimNo": "REIM2025",
  "reimTitle": "出差",
  "companyId": "COMP01"
}


###############################################################################
#  第五章: 亮点二 — 乐观锁 + 分布式锁并发控制机制
#
#  代码位置:
#    - service/impl/ReimMainServiceImpl.java  (saveReimMain + submitReim)
#    - entity/ReimMain.java                   (@Version 乐观锁字段)
#
#  验证目标:
#    1. 乐观锁: 使用过期version更新 → "数据已被修改，请刷新后重试"
#    2. 分布式锁: 同一报销单并发提交, 只有一个成功
#    3. 版本号递增机制正常
###############################################################################

