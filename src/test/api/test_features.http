Content-Type: application/json
user-id: EMP001

{
  "current": 1,
  "size": 5,
  "reimTitle": "杭州"
}


###
# 7.3 按报销单号搜索
POST {{fccApi}}/REIM_QueryPageList
Content-Type: application/json
user-id: EMP001

{
  "current": 1,
  "size": 10,
  "reimNo": "REIM2025"
}


###
# 7.4 按公司ID筛选
POST {{fccApi}}/REIM_QueryPageList
Content-Type: application/json

{
  "current": 1,
  "size": 10,
  "companyId": "COMP01"
}


###
# 7.5 查询预置测试数据详情 (reim001)
GET {{fccApi}}/REIM_GetDetail?id=reim001
user-id: user-001


###
# 7.6 更新报销单状态 (手动设置)
POST {{fccApi}}/REIM_UpdateStatus
Content-Type: application/json
user-id: user-001

{
  "id": "{{reimId}}",
  "status": 1
}


###
# 7.7 作废报销单 (仅"已完成"状态可作废)
POST {{fccApi}}/REIM_Cancel
Content-Type: application/json
user-id: user-001

{
  "id": "{{reimId}}"
}


###############################################################################
#  第七章: 边界与异常场景测试
###############################################################################

###
# 8.1 【异常】缺少所有必填字段 — 应返回参数校验错误 (code=400)
POST {{fccApi}}/REIM_Save
Content-Type: application/json

{
  "reimbursementTitle": "",
  "businessTripReason": "",
  "reimburserId": "",
  "reimburserName": "",
  "reimCompanyId": ""
}


###
# 8.2 【异常】查询不存在的报销单
GET {{fccApi}}/REIM_GetDetail?id=NONEXISTENT_ID_99999
user-id: user-001


###
# 8.3 【异常】查询不存在的导出任务
GET {{exportApi}}/status/non-existent-task-id


###
# 8.4 【异常】提交不存在的报销单 — 应返回 "报销单不存在"
POST {{fccApi}}/REIM_Submit
Content-Type: application/json
user-id: user-001

{
  "id": "NONEXISTENT_ID_00000",
  "version": 0
}


###
# 8.5 【异常】提交时缺少版本号 — 应返回参数错误
POST {{fccApi}}/REIM_Submit
Content-Type: application/json
user-id: user-001

{
  "id": "{{reimId}}"
}


###
# 8.6 【边界】重复提交已完成的报销单 — 应被状态校验拦截
POST {{fccApi}}/REIM_Submit
Content-Type: application/json
user-id: user-001

{
  "id": "{{reimId}}",
  "version": 1
}


###
# 8.7 【边界】作废一个草稿状态的报销单 — 应被状态校验拦截
POST {{fccApi}}/REIM_Cancel
Content-Type: application/json
user-id: user-001

{
  "id": "{{optLockReimId}}"
}


###
# 8.8 【边界】下载不存在或未完成的导出任务
GET {{exportApi}}/download/non-existent-task-id
