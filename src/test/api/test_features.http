###
# 6.3 【亮点二核心测试B】使用过期的版本号更新 — 应被乐观锁拦截!
# 此时 version 已经是 1 (上一步更新后递增), 再用 version=0 应失败
# 预期: code != 200, message = "数据已被修改，请刷新后重试"
POST {{fccApi}}/REIM_Save
Content-Type: application/json
user-id: user-002

{
  "id": "{{optLockReimId}}",
  "version": 0,
  "reimbursementTitle": "乐观锁测试-第二次更新(使用过期版本号应失败)",
  "businessTripReason": "这次更新携带过期的version=0应该被拦截",
  "reimburserId": "EMP003",
  "reimburserNo": "1003",
  "reimburserName": "并发测试员",
  "reimCompanyId": "COMP01",
  "subsidyTotal": 999.99,
  "tripList": [
