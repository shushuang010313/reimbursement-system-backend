    }
%}


###############################################################################
#  第三章: 🌟 亮点三 — 分布式最终一致性 (RabbitMQ DLX + 本地消息表 + 定时补偿)
#
#  代码位置:
#    - config/RabbitMQConfig.java           (交换机/队列/DLX定义)
#    - mq/BpmMessageListener.java           (消费者 + 死信消费者)
#    - job/BpmCompensationJob.java          (定时补偿任务, 每5分钟)
#    - entity/FkMqMessage.java              (本地消息表实体)
#
#  验证目标:
#    1. 提交报销单后，消息发送到 RabbitMQ
#    2. BpmMessageListener 消费时抛出异常 (模拟网络超时)
#    3. Spring-RabbitMQ 自动重试 3 次 (指数退避: 2s → 4s → 10s)
#    4. 3 次重试耗尽后，消息进入死信队列 (DLX: reim.dlx.queue)
#    5. DLX 消费者打印红色严重告警日志
#    6. 本地消息表 (fk_mq_message) 记录了发送状态
#    7. 定时补偿任务每5分钟扫描补偿
#
#  前置条件: 需要一个草稿状态的报销单
###############################################################################

###
# 4.1 【亮点三前置】保存一个用于MQ测试的草稿报销单
POST {{fccApi}}/REIM_Save
Content-Type: application/json
user-id: user-001

{
  "reimbursementTitle": "MQ死信队列测试-请勿删除",
  "businessTripReason": "测试分布式消息可靠性",
  "reimburserId": "EMP002",
  "reimburserNo": "1002",
  "reimburserName": "MQ测试员",
  "reimCompanyId": "COMP01",
  "reimCompanyNo": "C001",
  "reimCompanyName": "字节跳动科技有限公司",
  "subsidyTotal": 1600.00,
  "payeeIdCard": "420502199208089012",
  "payeeBankAccount": "622700100045678901",
  "tripList": [
    {
      "travelerId": "EMP002",
      "travelerNo": "1002",
      "travelerName": "MQ测试员",
      "departureCityId": "city010",
      "departureCityName": "北京",
      "arriveCityId": "city021",
      "arriveCityName": "上海",
      "arriveCityLevel": "1",
      "departureDate": "2025-11-10",
      "arriveDate": "2025-11-15",
